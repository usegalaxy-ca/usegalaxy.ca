#!/usr/bin/env python3
import argparse
import subprocess
import shutil
import os

def verify_dependencies() -> None:
    if not ansible_exists():
        print("Ansible is not installed. Please install ansible before running this script")
        exit(1)
    if not doppler_exists():
        print("Doppler is not installed. Please install doppler before running this script")
        exit(1)

def ansible_exists() -> bool:
    return shutil.which("ansible-playbook") is not None

def doppler_exists() -> bool:
    return shutil.which("doppler") is not None

class Ansible:
    def __init__(self) -> None:
        self.tags = []

    def add_tags(self, *tags: str) -> None:
        self.tags.extend(tags)

    def _build_command(self) -> list[str]:
        command = ["doppler", "run", "--", "ansible-playbook"] 
        tags = ["--tags", ",".join(self.tags)]
        command += tags + ["galaxy.yml"]
        return command

    def requirements(self) -> None:
        command = ["doppler", "run", "--", "ansible-galaxy", "install", "-p", "roles" , "-r", "requirements.yml"]
        env = {"ANSIBLE_FORCE_COLOR": "true"}
        self._cmd_run(command, env=env)

    def _cmd_run(self, command: list[str], env = {}) -> None:
        env = os.environ.copy()
        env.update(env)
        p = subprocess.Popen(command, shell=False, env=env)
        p.communicate()

    def run(self) -> None:
        command = self._build_command()
        env = {"ANSIBLE_FORCE_COLOR": "true"}
        self._cmd_run(command, env=env)

class ArgParser():
    def __init__(self):
        self.parser = argparse.ArgumentParser(
            prog="UseGalaxyCLI",
            description="Used to run commmon ansible recipes")
        subparsers = self.parser.add_subparsers(help='sub-command help')

        setup_command = subparsers.add_parser('setup', help="setup all components")
        setup_command.set_defaults(func=setup)

        setup_command = subparsers.add_parser('slurm', help="setup slurm")
        setup_command.set_defaults(func=slurm)

        setup_command = subparsers.add_parser('requirements', help="download all requirements")
        setup_command.set_defaults(func=requirements)

    def run(self) -> None:
        args = self.parser.parse_args()
        if not hasattr(args, "func"):
            self.parser.print_help()
            exit(1)
        args.func(args)



def main():
    verify_dependencies()
    parser = ArgParser()
    parser.run()

def requirements(args):
    ansible = Ansible()
    ansible.requirements()

def setup(args):
    ansible = Ansible()
    ansible.add_tags("setup")
    ansible.run()

def slurm(args):
    ansible = Ansible()
    ansible.add_tags("slurm", "nfs", "volume", "cvmfs")
    ansible.run()

if __name__ == "__main__":
    main()
