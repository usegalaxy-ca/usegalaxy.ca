{
  "compilerOptions": {
    "target": "es2016",
    "outDir": "bin",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "noUncheckedIndexedAccess": true,
    "module": "commonjs",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "Node"
  },
  "files": ["index.ts"],
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
